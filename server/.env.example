# Server
PORT=3001

# Gmail OAuth2 (for email scanning)
# Get these from Google Cloud Console -> APIs & Services -> Credentials
GMAIL_CLIENT_ID=your_client_id_here
GMAIL_CLIENT_SECRET=your_client_secret_here
GMAIL_REFRESH_TOKEN=your_refresh_token_here
GMAIL_USER_EMAIL=you@example.com

# Private routes are off by default. Enable only for loopback development.
ALLOW_PRIVATE_LOCAL=false
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# RapidAPI (optional - for enhanced Zillow/Realtor data)
RAPIDAPI_KEY=your_rapidapi_key_here

# Google Maps (optional - for map view)
GOOGLE_MAPS_API_KEY=your_maps_key_here
